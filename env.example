# Firebase Configuration (Public - OK to expose to client)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=renteriq-australia.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=renteriq-australia
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=renteriq-australia.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Domain.com.au API (Server-side ONLY - Never expose to client)
DOMAIN_CLIENT_ID=your_domain_client_id_here
DOMAIN_CLIENT_SECRET=your_domain_client_secret_here

# Gemini AI API (Server-side ONLY - Never expose to client)
GEMINI_API_KEY=your_gemini_api_key_here

# PropTrack API (optional, for future use)
PROPTRACK_API_KEY=your_proptrack_api_key_here
