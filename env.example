# Firebase Configuration (Public - OK to expose to client)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBzDc8M982iv-ndo2EU3T-5zPvXcRwdvKs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=renteriq-e1096.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=renteriq-e1096
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=renteriq-e1096.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1062935273922
NEXT_PUBLIC_FIREBASE_APP_ID=1:1062935273922:web:3d0d86e03baa4ec09f765b
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-F61WJ70RRP

# Firebase App Check (reCAPTCHA Enterprise site key). Generate at:
# Google Cloud Console -> Security -> reCAPTCHA Enterprise -> Create key
# (type: Website key, no domain verification needed for App Check).
# Then register it in Firebase Console -> App Check -> Web app -> reCAPTCHA Enterprise.
# Without this set the client-side App Check stays dormant and the server
# falls open. To make App Check mandatory, also set REQUIRE_APP_CHECK=true.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# Firebase Admin (Server-side ONLY). Generate a service account in
# Firebase Console -> Project Settings -> Service Accounts -> Generate Key.
# Paste values from the downloaded JSON. PRIVATE_KEY keeps its \n escapes.
FIREBASE_ADMIN_PROJECT_ID=renteriq-e1096
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@renteriq-e1096.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Domain.com.au API (Server-side ONLY - Never expose to client)
DOMAIN_CLIENT_ID=your_domain_client_id_here
DOMAIN_CLIENT_SECRET=your_domain_client_secret_here

# Gemini AI API (Server-side ONLY - Never expose to client)
GEMINI_API_KEY=your_gemini_api_key_here

# Emergency kill switch for every AI-backed route. Set to "true" in the
# hosting dashboard to halt Gemini usage instantly without a redeploy.
# Leave unset (or "false") in normal operation.
DISABLE_GEMINI_CALLS=false

# When set to "true", the API rejects any /api/ request that doesn't carry
# a verified X-Firebase-AppCheck header. Set this only after the site key
# above is provisioned and live in production — otherwise every API call
# will 401. Leave unset (or "false") during the wiring rollout.
REQUIRE_APP_CHECK=false

# Upstash Redis — shared rate limiter across all serverless instances.
# Sign up (free tier) at console.upstash.com → create a Redis database →
# copy the REST URL + REST Token. Without these, rate limiting falls back
# to per-instance in-memory limits (fine locally, loose in production).
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# PropTrack API (optional, for future use)
PROPTRACK_API_KEY=your_proptrack_api_key_here
