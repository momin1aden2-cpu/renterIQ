rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // User-scoped data
    // Path: users/{uid}/{collection}/{docId}
    // Only the owning user can read or write anything under their UID.
    //
    // CREDIT SCHEMA (pay-per-event, NOT subscription):
    //   users/{uid}/state/credits
    //     credits:           int  (current balance, never expires)
    //     cloudSyncEnabled:  bool (true = cloud sync purchased, $9.99 one-time)
    //     leaseReviewCount:  int  (tracks the 1st-free-ever freebie)
    //     lifetimeCredits:   int  (total ever purchased)
    //     betaCredited:      bool (true = 5 beta credits already granted)
    //
    //   users/{uid}/transactions/{txnId}
    //     type:        'credit_purchase' | 'cloud_sync_purchase'
    //     credits:     int (how many credits in this purchase)
    //     amount:      number (AUD cents)
    //     stripeId:    string (Stripe payment intent ID — null until live)
    //     status:      'pending' | 'completed' | 'refunded'
    //     createdAt:   timestamp
    //
    //   users/{uid}/usage/{usageId}
    //     feature:     'lease_review' | 'entry_condition' | 'routine_assist' | 'exit_bond_shield'
    //     credits:     int (how many credits consumed)
    //     createdAt:   timestamp
    //
    // ⚠️ SECURITY NOTE: During beta, the client can write credits
    // directly (needed for beta credit grants + offline-first decrments).
    // When Stripe goes live, lock credits writes to Cloud Functions:
    //   match /users/{userId}/state/credits {
    //     allow read: if request.auth.uid == userId;
    //     allow write: if false; // Only via admin SDK in Cloud Functions
    //   }
    // ─────────────────────────────────────────────────────────────
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────────
    // Legacy top-level routine_inspections collection
    // Existing data created before user-scoping. Read/write only your own.
    // ─────────────────────────────────────────────────────────────
    match /routine_inspections/{docId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────
    // Public reviews collection
    // - Anyone can READ all reviews (social proof / SEO)
    // - One review per UID — doc id must equal the writer's UID
    //   (anonymous auth gives every visitor a unique UID with no friction)
    // - Strict field validation prevents spam and abuse
    // - Updates allowed (users can edit their own review)
    // - Deletes blocked (prevents vote rigging)
    // ─────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == reviewId
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 800
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && request.auth.uid == reviewId
        && resource.data.uid == request.auth.uid
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.comment.size() <= 800;

      allow delete: if false;
    }

    // Default deny — anything not matched above is forbidden.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
