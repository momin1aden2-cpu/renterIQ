rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User-scoped data. Paths under users/{uid} are readable/writable
    // only by the owning user.
    //
    // Credit schema (pay-per-event):
    //   users/{uid}/state/credits       — balance, sync flag, lifetime counters
    //   users/{uid}/transactions/{id}   — credit / cloud sync purchases
    //   users/{uid}/usage/{id}          — consumption records per feature
    //
    // During beta the client can write credits directly (needed for beta
    // grants and offline-first decrements). Before Stripe goes live, move
    // credit writes behind Cloud Functions by narrowing this block.
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Legacy top-level routine_inspections. Read/write own documents only.
    match /routine_inspections/{docId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Public reviews. Anyone can read; one review per uid (docId == uid).
    // Field validation guards spam; deletes blocked so scores can't be gamed.
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == reviewId
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 800
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && request.auth.uid == reviewId
        && resource.data.uid == request.auth.uid
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.comment.size() <= 800;

      allow delete: if false;
    }

    // Anonymous usage counters — aggregate only, no personal data.
    // Clients can increment counts; reads restricted to authenticated users
    // (Mumin can view in Firebase Console regardless).
    match /metrics/{eventName} {
      allow create, update: if true;
      allow read: if request.auth != null;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
