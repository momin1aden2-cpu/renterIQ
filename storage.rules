rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────
    // User-scoped file storage
    // Path: users/{uid}/{folder}/{file}
    //   - users/{uid}/leases/{leaseId}.pdf
    //   - users/{uid}/entry-audits/{auditId}/{photoId}.jpg
    //   - users/{uid}/exit-audits/{auditId}/{photoId}.jpg
    //   - users/{uid}/personal-docs/{docId}.{ext}
    //   - users/{uid}/receipts/{receiptId}.{ext}
    //   - users/{uid}/maintenance/{itemId}/{photoId}.jpg
    // ─────────────────────────────────────────────────────────────
    match /users/{userId}/{allPaths=**} {
      // Read: only the owner
      allow read: if request.auth != null && request.auth.uid == userId;

      // Write: only the owner, max 15MB per file, common renter file types
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          request.resource == null  // delete
          || (
            request.resource.size < 15 * 1024 * 1024
            && (
              request.resource.contentType.matches('image/.*')
              || request.resource.contentType == 'application/pdf'
              || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
              || request.resource.contentType == 'application/msword'
            )
          )
        );
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
